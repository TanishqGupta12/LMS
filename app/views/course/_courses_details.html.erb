			<input type="hidden" class="form-control" name="course" data-stripe-target="course" value=" <%= @courses.try(:id) %>">
			<input type="hidden" class="form-control" name="user" data-stripe-target="user" value=" <%= current_user.try(:id) %>">
			<input type="hidden" class="form-control" name="teacher" data-stripe-target="teacher" value=" <%= @courses.try(:teacher).try(:id) %>">
		</form>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
		<% if @courses.try(:is_paid) %>
			<button type="button" class="btn btn-primary" data-action="click->stripe#payment">Payment</button>
		<% else %>
			<button type="button" class="btn btn-primary" data-action="click->stripe#free_payment">Payment now</button>
		<% end %>
      </div>
    </div>
  </div>
</div>

