


    <!-- Blog Start -->
    <div class="container-fluid py-5">
        <div class="container py-5">
            <div class="row">
                <div class="col-lg-8">
                    <div class="row pb-3">
                        <% @blogs.each do |blog| %>
                            <div class="col-lg-6 mb-4">
                                <div class="blog-item position-relative overflow-hidden rounded mb-2">
                                    <img class="img-fluid" src="<%= url_for(blog.image)%>" alt="">
                                    <a class="blog-overlay text-decoration-none" href="<%= event_blog_path(blog.event, blog)%>">
                                        <h5 class="text-white mb-3"><%= blog.try(:title)%></h5>
                                        <p class="text-primary m-0"><%= blog.try(:created_at).strftime("%Y-%m-%d") %></p>
                                        <small class="text-primary m-0"> created_by :<%= blog.try(:user).try(:name) %></small>
                                    </a>
                                </div>
                            </div>
                        <%end %>
                    </div>
                </div>
    
             <%= render partial: "side_menu", locals: { categorys: @categorys  , blogs_recenlty: @blogs_recenlty} %>
            </div>
        </div>
    </div>
    <!-- Blog End -->

