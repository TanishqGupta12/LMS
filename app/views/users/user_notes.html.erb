  <%= stylesheet_link_tag 'custom_style'%>

<%= render partial: "user_header" , locals: { user: @user } %>

<div class="section-main pt-0">
	<div class="container">
		<div class="row">
			<%= render partial: "profile_side_bar" %>
			<!-- Main content START -->

			<div class="col-xl-9">

				<!-- Counter boxes END -->
				<div class="card bg-transparent border rounded-3">
					<!-- Card header START -->
					<div class="card-header bg-transparent border-bottom">
						<h3 class="mb-0">My Notes</h3>
					</div>
					<!-- Card header END -->

					<!-- Card body START -->
					<div class="card-body">

						<!-- Course list table START -->
						<div class="table-responsive border-0">
							<table class="table table-dark-gray align-middle p-4 mb-0 table-hover">
								<!-- Table head -->
								<thead>
									<tr>
										<th scope="col" class="border-0 rounded-start">Course Title</th>
										<th scope="col" class="border-0">Lectures</th>
										<th scope="col" class="border-0">TimeStamp</th>
										<th scope="col" class="border-0 rounded-end">Action</th>
									</tr>
								</thead>

								<!-- Table body START -->
								<tbody>
									<!-- Table item -->

									<% @user_notes.each do |user_course| %>
									<tr>
										<!-- Table data -->
										<td>
											<div class="d-flex align-items-center">
												
												<div class="mb-0 ms-2">
													<!-- Title -->
													<h6><%= user_course.try(:course).try(:title) %></h6>
													<!-- Info -->
												</div>
											</div>
										</td>

										<!-- Table data -->
										<td><%= (user_course.try(:lesson).try(:title)) %></td>

										<!-- Table data -->
										<td> <%= (user_course.try(:timestamp)) %></td>

										<!-- Table data -->
										<td data-controller="user-note">
											<input data-user-note-target="user" type="hidden" value="<%= params[:id] %>" />
											<input data-user-note-target="lesson" type="hidden" value="<%= user_course.try(:course).try(:id) %>" />
											<input data-user-note-target="timestamp" type="hidden" value="<%= (user_course.try(:timestamp)) %>" />

											<a href="/<%= @event.try(:id) %>/course/<%= user_course.try(:course).try(:id) %>?time=<%= CGI.escape(user_course.try(:timestamp).to_s) %>" class="btn btn-sm btn-primary-soft me-1 mb-1 mb-md-0">
												<i class="bi bi-play-circle me-1"></i>video
											</a>
											<a  href="#" data-action="user-note#submit" class="btn btn-sm btn-primary-soft me-1 mb-1 mb-md-0">
												<i class="bi bi-play-circle me-1"></i>Show
											</a>
											<%= button_to user_note_path(lesson: user_course.try(:lesson).try(:id)), method: :delete, class: "btn btn-sm btn-primary-soft me-1 mb-1 mb-md-0" do %>
												<i class="fa fa-solid fa-trash me-1"></i> Delete
											<% end %>
										</td>
									</tr>
									<% end %>

								</tbody>
								<!-- Table body END -->
							</table>
						</div>
						<!-- Course list table END -->

					</div>
					<!-- Card body START -->
				</div>
			</div>

			<!-- Main content END -->
		</div>
		<div class="user_notes" data-user-note-target="container">
			
		</div>
	</div>	
</div>