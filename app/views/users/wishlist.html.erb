  <%= stylesheet_link_tag 'custom_style'%>

<%= render partial: "user_header" , locals: { user: @user } %>

<section class="pt-0">
	<div class="container">
		<div class="row">
			<%= render partial: "profile_side_bar" %>

            <!-- Main content START -->
                <div class="col-xl-9">

                    <div class="card bg-transparent border rounded-3">
                        <!-- Card header START -->
                        <div class="card-header bg-transparent border-bottom">
                            <h3 class="mb-0">WishList</h3>
                        </div>
                        <!-- Card header END -->

                        <!-- Card body START -->
                        <div class="card-body p-3 p-md-4">
                            <div class="row g-4">
                                <% @favorited_course.each do |favorited_course| %>
                                <!-- Card item START -->
                                <div class="col-sm-6 col-lg-4">
                                    <div class="card shadow h-100">
                                        <!-- Image -->
                                        <img src="<%= url_for(favorited_course.thumbail)%>" class="card-img-top" alt="course image">
                                        <div class="card-body pb-0">
                                            <!-- Badge and favorite -->
                                            <div class="d-flex justify-content-between mb-2">
                                                <a href="#" class="badge bg-success bg-opacity-10 text-success"><%= (favorited_course.language)%></a>
                                                <div class="favorite-link_<%= favorited_course.try(:id) %>">
											        <%= render partial: "course/favorite_button", locals: { course: favorited_course, event: @event }%>
										        </div>
                                            </div>
                                            <!-- Title -->
                                            <h5 class="card-title fw-normal"><a href="<%= event_course_path(@user.current_event_id , favorited_course.try(:id))%>"><%= (favorited_course.title)%></a></h5>

                                            
                                            <!-- Rating star -->
                                            <ul class="list-inline mb-0">
                                                <li class="list-inline-item me-0 small"><i class="fas fa-star text-warning"></i></li>
                                                <li class="list-inline-item me-0 small"><i class="fas fa-star text-warning"></i></li>
                                                <li class="list-inline-item me-0 small"><i class="fas fa-star text-warning"></i></li>
                                                <li class="list-inline-item me-0 small"><i class="fas fa-star text-warning"></i></li>
                                                <li class="list-inline-item me-0 small"><i class="fas fa-star-half-alt text-warning"></i></li>
                                                <li class="list-inline-item ms-2 h6 fw-light mb-0">4.5/5.0</li>
                                            </ul>
                                        </div>
                                        <!-- Card footer -->
                                        <div class="card-footer pt-0 pb-3">
                                            <hr>
                                            <div class="d-flex justify-content-between">
                                                <span class="h6 fw-light mb-0"><i class="far fa-clock text-danger me-2"></i><%= (favorited_course.duration) %></span>
                                                <span class="h6 fw-light mb-0"><i class="fas fa-table text-orange me-2"></i><%= (favorited_course.quiz_topics).size %></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <!-- Card item END -->
                                <%  end %>
                            </div>
                        </div>
                        <!-- Card body EMD -->
                    </div>  
                </div>
			<!-- Main content END -->
        </div>
    </div>
</section>