
<!-- =======================
Page Banner START -->
  <%= stylesheet_link_tag 'custom_style'%>

<%= render partial: "user_header" , locals: { user: @user } %>
<!-- =======================
Page Banner END -->

<div class="section-main pt-0">
	<div class="container">
		<div class="row">
			<%= render partial: "profile_side_bar" %>
			<!-- Main content START -->
			<% user_courses =  @user_courses %>
			<div class="col-xl-9">
				<!-- Counter boxes START -->
				<div class="row mb-4">
					<!-- Counter item -->
					<div class="col-sm-4 col-lg-4 mb-3 mb-lg-0">
						<div class="d-flex justify-content-center align-items-center p-4 bg-orange bg-opacity-15 rounded-3">
							<span class="display-6 lh-1 text-orange mb-0"><i class="fas fa-tv fa-fw"></i></span>
							<div class="ms-4">
								<div class="d-flex">
									<h5 class="purecounter mb-0 fw-bold" data-purecounter-start="0" data-purecounter-end="9"	data-purecounter-delay="200"><%=  user_courses.count %></h5>
								</div>
								<p class="mb-0 h6 fw-light">Total Courses</p>
							</div>
						</div>
					</div>
					<!-- Counter item -->
					<div class="col-sm-4 col-lg-4 mb-3 mb-lg-0">
						<div class="d-flex justify-content-center align-items-center p-4 bg-purple bg-opacity-15 rounded-3">
							<span class="display-6 lh-1 text-purple mb-0"><i class="fas fa-clipboard-check fa-fw"></i></span>
							<div class="ms-4">
								<div class="d-flex">
									<h5 class="purecounter mb-0 fw-bold" data-purecounter-start="0" data-purecounter-end="52"	data-purecounter-delay="200"><%= user_courses.try(:completed_lession) || '0' %>  </h5>
								</div>
								<p class="mb-0 h6 fw-light">Complete lessons</p>
							</div>
						</div>
					</div>
					<!-- Counter item -->
					<div class="col-sm-4 col-lg-4 mb-3 mb-lg-0">
						<div class="d-flex justify-content-center align-items-center p-4 bg-success bg-opacity-10 rounded-3">
							<span class="display-6 lh-1 text-success mb-0"><i class="fas fa-medal fa-fw"></i></span>
							<div class="ms-4">
								<div class="d-flex">
									<h5 class="purecounter mb-0 fw-bold" data-purecounter-start="0" data-purecounter-end="8" data-purecounter-delay="300"><%= user_courses.where.not(certificate_url: [nil, '']).count%></h5>
								</div>
								<p class="mb-0 h6 fw-light">Achieved Certificates</p>
							</div>
						</div>
					</div>
				</div>

				<!-- Counter boxes END -->
				<div class="card bg-transparent border rounded-3">
					<!-- Card header START -->
					<div class="card-header bg-transparent border-bottom">
						<h3 class="mb-0">My Courses List</h3>
					</div>
					<!-- Card header END -->

					<!-- Card body START -->
					<div class="card-body">

						<!-- Course list table START -->
						<div class="table-responsive border-0">
							<table class="table table-dark-gray align-middle p-4 mb-0 table-hover">
								<!-- Table head -->
								<thead>
									<tr>
										<th scope="col" class="border-0 rounded-start">Course Title</th>
										<th scope="col" class="border-0">Total Lectures</th>
										<th scope="col" class="border-0">Completed Lecture</th>
										<th scope="col" class="border-0 rounded-end">Action</th>
									</tr>
								</thead>

								<!-- Table body START -->
								<tbody>
									<!-- Table item -->

									<% user_courses.each do |user_course| %>
									<tr>
										<!-- Table data -->
										<td>
											<div class="d-flex align-items-center">
												<!-- Image -->
												<div class="w-100px">
													<img src="<%= url_for(user_course.try(:course).try(:thumbail)) %>" class="rounded" alt="">
												</div>
												<div class="mb-0 ms-2">
													<!-- Title -->
													<h6><%= user_course.try(:course).try(:title) %></h6>
													<!-- Info -->
													<div class="overflow-hidden">
														<h6 class="mb-0 text-end">  <%= (user_course.try(:percentage).to_f * 100).round(0) %>%</h6>
														<div class="progress progress-sm bg-primary bg-opacity-10">
															<div class="progress-bar bg-primary aos" role="progressbar" data-aos="slide-right" data-aos-delay="200" data-aos-duration="1000" data-aos-easing="ease-in-out" style="width: 85%" aria-valuenow="85" aria-valuemin="0" aria-valuemax="100">
															</div>
														</div>
													</div>
												</div>
											</div>
										</td>

										<!-- Table data -->
										<td><%= (user_course.try(:courses).try(:lessons)) %></td>

										<!-- Table data -->
										<td><%= (user_course.try(:completed_lession).try(:count).to_f * 100).round(0) %></td>

										<!-- Table data -->
										<td>
											<% if user_course.try(:completed).present? %>
												<button class="btn btn-sm btn-success me-1 mb-1 mb-x;-0 disabled text-decoration-none"><i class="bi bi-check me-1"></i>Complete</button>
											<% else %>
												<a href="#" class="btn btn-sm btn-primary-soft me-1 mb-1 mb-md-0"><i class="bi bi-play-circle me-1"></i>Continue</a>
												<a href="#" class="btn btn-sm btn-light me-1 text-decoration-none"><i class="bi bi-arrow-repeat me-1"></i>Restart</a>
											<% end %>
										</td>
									</tr>
									<% end %>

								</tbody>
								<!-- Table body END -->
							</table>
						</div>
						<!-- Course list table END -->

					</div>
					<!-- Card body START -->
				</div>
			</div>

			<!-- Main content END -->
		</div>
	</div>	
</div>