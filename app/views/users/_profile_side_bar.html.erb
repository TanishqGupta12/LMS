

    <!-- Left sidebar START -->
    <div class="col-xl-3">
        <!-- Responsive offcanvas body START -->
        <div class="offcanvas-xl offcanvas-end" tabindex="-1" id="offcanvasSidebar">
            <!-- Offcanvas header -->
            <div class="offcanvas-header bg-light">
                <h5 class="offcanvas-title" id="offcanvasNavbarLabel">My profile</h5>
                <button  type="button" class="btn-close" data-bs-dismiss="offcanvas" data-bs-target="#offcanvasSidebar" aria-label="Close"></button>
            </div>
            <!-- Offcanvas body -->
            <div class="offcanvas-body p-3 p-xl-0">
                <div class="bg-dark border rounded-3 p-3 w-100">
                    <!-- Dashboard menu -->
                    <div class="list-group list-group-dark list-group-borderless collapse-list">
                        <a class="list-group-item text-decoration-none" href="<%= user_path(params[:id]) %>"><i class="bi bi-ui-checks-grid fa-fw me-2"></i>Dashboard</a>
                        <a class="list-group-item d-none text-decoration-none" href="student-subscription.html"><i class="bi bi-card-checklist fa-fw me-2"></i>My Subscriptions</a>
                        <a class="list-group-item d-none text-decoration-none" href="student-course-list.html"><i class="bi bi-basket fa-fw me-2"></i>My Courses</a>
                        <a class="list-group-item text-decoration-none d-none" href="<%= course_resume_user_path(params[:id])%>"><i class="far fa-fw fa-file-alt me-2"></i>Course Resume</a>
                        <a class="list-group-item d-none text-decoration-none" href="student-quiz.html"><i class="bi bi-question-diamond fa-fw me-2"></i>Quiz</a>
                        <a class="list-group-item text-decoration-none" href="<%= payment_info_user_path(params[:id]) %>"><i class="bi bi-credit-card-2-front fa-fw me-2"></i>Payment Info</a>
                        <a class="list-group-item text-decoration-none" href="<%= wishlist_user_path(params[:id])%>"><i class="bi bi-cart-check fa-fw me-2"></i>Wishlist</a>
                        <a class="list-group-item text-decoration-none" href="<%= edit_user_path %>"><i class="bi bi-pencil-square fa-fw me-2"></i>Edit Profile</a>
                        <a class="list-group-item d-none text-decoration-none" href="instructor-setting.html"><i class="bi bi-gear fa-fw me-2"></i>Settings</a>
                        <a class="list-group-item text-decoration-none" href="<%= user_notes_user_path(params[:id])%>"><i class="bi bi-journal-text me-2"></i>My Notes</a>
                        <a class="list-group-item text-decoration-none" href="#" data-toggle="modal" data-target="#deleteAccountModal" ><i class="bi bi-trash fa-fw me-2"></i>Delete Profile</a>
                        <a class="list-group-item text-danger bg-danger-soft-hover text-decoration-none" href="<%= destroy_user_session_path()%>"><i class="fas fa-sign-out-alt fa-fw me-2"></i>Sign Out</a>
                    </div>
                </div>
            </div>
        </div>
        <!-- Responsive offcanvas body END -->
    </div>
    <!-- Left sidebar END -->


    <div class="modal fade" id="deleteAccountModal" tabindex="-1" aria-labelledby="deleteAccountLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
        <div class="modal-header">
            <h5 class="modal-title" id="deleteAccountLabel">Confirm Deletion</h5>
            <button type="button" class="btn-close" data-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
            Are you sure you want to delete your account? 
            <p> Email: <%= current_user.try(:email)%> </p>
        </div>
        <div class="modal-footer">
            <%= button_to "Delete Profile", user_path(params[:id]), 
            method: :delete, 
            class: "btn btn-danger text-decoration-none text-white", 
            data: { remote: true, turbo: false} 
            %>
            <button type="button" class="btn btn-secondary " data-dismiss="modal" >Cancel</button>
        </div>
        </div>
    </div>
    </div>
    <script>
        $('#deleteAccountLabel').on('show.bs.modal', function (event) {

         })
    </script>