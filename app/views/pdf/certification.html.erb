<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Elegant Certificate of Completion</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600&family=Open+Sans&display=swap" rel="stylesheet">
  <style>
    body {
      background: #f2f2f2;
      font-family: 'Open Sans', sans-serif;
    }

    .certificate {
      background: white;
      border: 12px double #d4af37;
      padding: 60px 40px;
      margin: 50px auto;
      max-width: 900px;
      box-shadow: 0 0 15px rgba(0,0,0,0.2);
      position: relative;
    }

    .certificate h1 {
      font-family: 'Playfair Display', serif;
      color: #222;
      font-size: 3.2rem;
      font-weight: 600;
    }

    .certificate h2 {
      font-size: 2rem;
      margin: 20px 0;
      color: #000;
    }

    .certificate .subtitle {
      font-size: 1.2rem;
      margin-bottom: 20px;
      color: #555;
    }

    .certificate .highlight {
      color: #d4af37;
      font-weight: bold;
    }

    .certificate .line {
      border-top: 2px dashed #aaa;
      margin: 30px 0;
    }

    .footer {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 50px;
    }

    .signature-box {
      text-align: center;
    }

    .signature-box p {
      margin-bottom: 0;
    }

    .logo img {
      height: 60px;
    }

    .ribbon {
      position: absolute;
      top: -30px;
      right: -30px;
      background: #d4af37;
      color: white;
      padding: 8px 20px;
      transform: rotate(45deg);
      font-weight: bold;
      box-shadow: 0 0 5px rgba(0,0,0,0.2);
    }
  </style>
</head>
<body>

<div class="container">
  <div class="certificate text-center">
    <div class="ribbon">AWARD</div>

    <h1>Certificate of Completion</h1>
    <p class="subtitle">This is proudly presented to</p>
    <h2>[Recipient Name]</h2>
    <p>for successfully completing the</p>
    <h3 class="highlight">[Course Name]</h3>
    <p class="mt-3">Date: <span class="highlight">[Date]</span></p>

    <div class="line"></div>

    <div class="footer">
      <div class="signature-box">
        <p>_______________________</p>
        <p>Instructor</p>
      </div>
      <div class="logo">
        <img src="logo.png" alt="Logo">
      </div>
      <div class="signature-box">
        <p>_______________________</p>
        <p>Director</p>
      </div>
    </div>
  </div>
<div>
</body>
</html>

<%= 

# course.try(:certification).html_safe  

%>
