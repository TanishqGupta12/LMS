<script>
  function updateFormAction(action) {
    document.getElementById('bulk-form').action = action;
  }
</script>
<div class="container">
  <% if params[:review] == 'true' %>
  <div class="header text-center d-block">
    <h1 class="text-decoration-none">
      <span style= "color: #fff;"><%= @course.try(:title) %></span>
    </h1>
  </div>
  <div class="result-section">

    <% if @course && @quiz_attempts && @course.total_marks.to_f > 0 %>
        <% percentage = ((@quiz_attempts.marks_gained.to_f / @course.total_marks) * 100).round %>

        <div class="progress-bar">
          <div class="progress" style="width: <%= percentage %>%"></div>
          <span class="progress-text"><%= percentage %>%</span>
        </div>
    <% end %>

      <div class="score-section">
          <div class="score-box">
              <p>Total Marks</p>
              <h4><%= @course.try(:total_marks) %></h4>
          </div>
          <div class="score-box">
              <p>Marks Gained</p>
              <h4><%= @quiz_attempts.try(:marks_gained) %></h4>
          </div>
      </div>
  </div>
  <% end %>
  <div class="formbold-main-wrapper  <% if params[:review] == 'true' %> question-section <% end %>">
   
      <div class="formbold-form-wrapper">
        
        <form id="bulk-form"  method="POST">
            <input type="hidden"  name="quiz_topic" value="<%= params[:quiz_topic] %>"/>
            <input type="hidden"  name="lesson" value="<%= params[:lesson] %>"/> 
            <input type="hidden"  name="course" value="<%= @course.id %>"/> 
              <input type="hidden"  name="quiz_attempts" value="<%= @quiz_attempts.try(:id) %>"/>
        
        <% @questions.each do |question|%>
          <div class="formbold-mb-5">
            <input type="hidden"  name="question_tpes" value="<%= question.try(:question_type) %>"/>
            <label id="qus_<%= question.id %>" class="formbold-form-label">
              <%= question.try(:title)%>
              <input type="hidden"  name="answers[<%= question.id %>][question_id]" value="<%= question.id %>"/>
            </label>

            <% if question.try(:question_type) == "Multiple Choice Single Option" %>
                <%= render partial: "single_option", locals: { question: question} %>
            <% elsif question.try(:question_type) == "Multiple Choice Multiple option" %>
                <%= render partial: "multiple_option", locals: { question: question} %>
            <% elsif question.try(:question_type) == "True False" %>
                <%= render partial: "true_false", locals: { question: question} %>
            <% elsif question.try(:question_type) == "Short Answer" %> 
                <%= render partial: "short_answer", locals: { question: question} %>
            <% end %>
          </div>
        <% end %>
            <% if !@result.present? %>
              <% if params[:review] == 'true' %> <!-- Compare as string -->
              <button class="formbold-btn" onclick="updateFormAction('<%= quiz_full_submit_path(params[:quiz_topic]) %>')"> Final Submit</button>

              <a class="formbold-btn" href= '<%= quiz_index_path(quiz_topic: params[:quiz_topic], lesson: params[:lesson], review: 'false') %>' style="background-color: green; text-decoration: none; color: white;"> Edit</a>
              <% else %>
              <button class="formbold-btn" onclick="updateFormAction('<%= quiz_review_path(params[:quiz_topic]) %>')">Submit</button>
              <% end %>
            <% end %>
        </form>
      </div>
    
  </div>
</div>
