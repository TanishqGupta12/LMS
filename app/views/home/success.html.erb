<style>
  .cancel {
    height: 30vh;
  }
</style>

<div class="cancel">
  <div class="container">
    <div class="alert alert-danger mt-4 text-center" role="alert">
      <h4 class="alert-heading">Payment Cancelled</h4>
      <p>Your payment process was cancelled. No charges were made.</p>
      <hr>
      <p class="mb-0">You can retry payment or return to the homepage.</p>
      <a href="<%= root_path %>" class="btn btn-danger mt-3">Go to Homepage</a>
    </div>
  </div>
</div>
