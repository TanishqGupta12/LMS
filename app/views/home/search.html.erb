<style>

.container-body  {
  height: 100%;
}

  .footer-search-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    padding: 1em 0;
  }

  .search-golabnl {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  input[type=search] {
    border: 1px solid #44425A;
    box-sizing: border-box;
    font-size: 1.25rem;
    height: 3em;
    padding: 0.5em 1em;
    width: 80vw; /* makes the input large */
    max-width: 1000px;
    border-radius: 8px;
    outline: none;
    transition: all 0.3s ease-in-out;
  }

  input[type=search]:focus {
    border-color: #FF6600;
    box-shadow: 0 0 6px rgba(255, 102, 0, 0.6);
  }

  #search_results {
    /* max-height: 200px;
    overflow-y: auto; */
    margin-top: 5em !important;
    /* width: 80vw;
    max-width: 1000px; */
  }

  @media (max-width: 768px) {
    input[type=search],
    #search_results {
      width: 95vw;
    }
  }
</style>

<div class="container container-body" data-controller="search">
  <div class="footer-search-container">
    <form class="search-golabnl">
      <input data-search-target="input"
             type="search"
             id="form1"
             class="form-control"
             placeholder="Type query"
             aria-label="Search"
             data-action="input->search#search" />
    </form>
    <div id="search_results" data-search-target="results"></div>
  </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
  $(document).ready(function() {
    // $('#nav_box').hide();
    $('#Footer_box').hide();
  });
</script>